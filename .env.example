# Upstream backend API URL used by the Next.js /api proxy (see next.config.mjs)
# Production:
NEXT_PUBLIC_API_BASE_URL=https://api.motogt.com/api

# Local backend (requires MotoGT API running on port 3001):
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api

# The dashboard sends browser requests to /api/* on the same origin.
# Next.js rewrites those requests to NEXT_PUBLIC_API_BASE_URL.

# Optional app name override
# NEXT_PUBLIC_APP_NAME=MotoGT Admin Dashboard
