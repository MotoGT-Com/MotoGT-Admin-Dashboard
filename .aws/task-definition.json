{
  "family": "motgt-admin-dashboard",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::653306034344:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::653306034344:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "motgt-admin-container",
      "image": "653306034344.dkr.ecr.me-central-1.amazonaws.com/motgt-admin-dashboard:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "NODE_ENV",
          "value": "production"
        },
        {
          "name": "PORT",
          "value": "3000"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/motgt-admin-dashboard",
          "awslogs-region": "me-central-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "wget --no-verbose --tries=1 --spider http://localhost:3000 || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
